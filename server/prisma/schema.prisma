generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                Int      @id @default(autoincrement())
  name              String
  category          String
  price             Float //nbre décimal(pour les prix)
  stock             Int
  lowStockThreshold Int
  soldLast7Days     Int      @default(0)
}
